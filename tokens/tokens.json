{
  "$meta": {
    "description": "Canonical design tokens for GGX Corporate — single source of truth. Both the code theme (src/styles/theme.css) and the Figma design-system variables are GENERATED from this file. Do not hand-edit theme.css or the Figma radius/spacing/color variables directly; edit here and regenerate.",
    "generators": {
      "css": "node scripts/build-tokens.mjs  -> src/styles/theme.css",
      "figma": "node scripts/sync-figma-variables.mjs  -> Figma DS variables (requires FIGMA_TOKEN)"
    },
    "version": "1.0.0"
  },

  "color": {
    "background": "#ffffff",
    "foreground": "oklch(0.145 0 0)",
    "card": "#ffffff",
    "card-foreground": "oklch(0.145 0 0)",
    "popover": "oklch(1 0 0)",
    "popover-foreground": "oklch(0.145 0 0)",
    "primary": "#0088C9",
    "primary-foreground": "#EBFCFF",
    "secondary": "oklch(0.95 0.0058 264.53)",
    "secondary-foreground": "#030213",
    "muted": "#ececf0",
    "muted-foreground": "#717182",
    "accent": "#e9ebef",
    "accent-foreground": "#030213",
    "destructive": "#d4183d",
    "destructive-foreground": "#ffffff",
    "border": "rgba(0, 0, 0, 0.1)",
    "input": "transparent",
    "input-background": "#f3f3f5",
    "switch-background": "#cbced4",
    "ring": "oklch(0.708 0 0)",
    "chart-1": "oklch(0.646 0.222 41.116)",
    "chart-2": "oklch(0.6 0.118 184.704)",
    "chart-3": "oklch(0.398 0.07 227.392)",
    "chart-4": "oklch(0.828 0.189 84.429)",
    "chart-5": "oklch(0.769 0.188 70.08)",
    "sidebar": "oklch(0.985 0 0)",
    "sidebar-foreground": "oklch(0.145 0 0)",
    "sidebar-primary": "#030213",
    "sidebar-primary-foreground": "oklch(0.985 0 0)",
    "sidebar-accent": "oklch(0.97 0 0)",
    "sidebar-accent-foreground": "oklch(0.205 0 0)",
    "sidebar-border": "oklch(0.922 0 0)",
    "sidebar-ring": "oklch(0.708 0 0)"
  },

  "scalar": {
    "font-size": "16px",
    "font-weight-medium": "500",
    "font-weight-normal": "400"
  },

  "font": {
    "sans": "'Inter', ui-sans-serif, system-ui, sans-serif"
  },

  "radius": {
    "$comment": "shadcn-derived scale. `base` is authored; sm/md/lg/xl are derived for @theme inline. `px` is the resolved pixel value used to sync Figma variables — this is the scale Figma's radius variables MUST match (currently the DS uses the vanilla Tailwind scale 2/6/8/12 and is out of sync).",
    "base": "0.625rem",
    "css": {
      "sm": "calc(var(--radius) - 4px)",
      "md": "calc(var(--radius) - 2px)",
      "lg": "var(--radius)",
      "xl": "calc(var(--radius) + 4px)"
    },
    "px": {
      "sm": 6,
      "md": 8,
      "lg": 10,
      "xl": 14
    }
  }
}
